{
  "name": "@axlpq/ai-coding-workflow",
  "version": "1.0.6",
  "description": "AI coding assistant workflow skill library — Superpowers + OpenSpec team skills for Codex, Cursor, and Claude Code",
  "bin": {
    "spec": "./bin/spec.js"
  },
  "scripts": {
    "build": "node scripts/build-dist.js",
    "test": "node scripts/test-spec-init.js",
    "postinstall": "echo 'AI coding workflow skills installed. Run: npx spec --help'",
    "prepublishOnly": "npm run build && node -e \"const fs=require('fs'); ['dist','team-skills','scripts','templates'].forEach(d=>{if(!fs.existsSync(d)){console.error('Missing: '+d);process.exit(1)}})\""
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "templates/",
    "team-skills/",
    "README.md",
    "README.cn.md",
    "README.zh.md"
  ],
  "keywords": [
    "superpowers",
    "openspec",
    "ai-workflow",
    "claude-code",
    "cursor",
    "codex",
    "tdd",
    "ai-coding"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
